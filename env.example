import React, { useState } from "react";
import { BrainCircuit, Sparkles, Send, Coins, BarChart as ChartIcon, HelpCircle } from "lucide-react";
import { User, Sale } from "../types";
import { ResponsiveContainer, BarChart, Bar, XAxis, YAxis, CartesianGrid, Tooltip } from "recharts";
import { motion } from "motion/react";

interface AskGeminiTabProps {
  user: User;
  sales: Sale[];
  token: string;
}

export default function AskGeminiTab({ user, sales, token }: AskGeminiTabProps) {
  const [question, setQuestion] = useState("");
  const [answer, setAnswer] = useState("");
  const [loading, setLoading] = useState(false);

  const QUICK_PROMPTS = [
    { text: "💰 Profit Analysis", query: "Which product is most profitable, and how can I hike margins?" },
    { text: "🛒 Stock Replenish", query: "What should I buy more of tomorrow based on weekend sales trends?" },
    { text: "♻️ Waste Audit", query: "Which product am I overstocking and risking wastage this week?" },
    { text: "📅 Best Day", query: "What is my best performing day of the week, and why?" }
  ];

  const handleAskAI = async (queryText: string) => {
    const activeQuery = queryText || question.trim();
    if (!activeQuery) return;

    setLoading(true);
    setAnswer("");
    if (!queryText) setQuestion("");

    try {
      const response = await fetch("/api/gemini/ask", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Authorization": `Bearer ${token}`
        },
        body: JSON.stringify({ question: activeQuery })
      });

      const data = await response.json();
      if (!response.ok) {
        throw new Error(data.error || "Failed to communicate with Gemini.");
      }

      setAnswer(data.answer);
    } catch (err: any) {
      setAnswer(`❌ Gemini Processing Error:\n${err.message}`);
    } finally {
      setLoading(false);
    }
  };

  // Compile daily revenue bars for the bar graph
  const getRevenueHistoryData = () => {
    if (sales.length === 0) return [];

    const dateSum: Record<string, number> = {};
    sales.forEach((s) => {
      dateSum[s.date] = (dateSum[s.date] || 0) + s.revenue;
    });

    return Object.keys(dateSum)
      .sort()
      .map((dateStr) => ({
        date: dateStr.slice(5), // MM-DD
        Revenue: dateSum[dateStr]
      }));
  };

  const revenueData = getRevenueHistoryData();

  return (
    <div className="space-y-6 font-sans">
      {/* Ask Gemini section */}
      <div className="bg-brand-surface rounded-3xl border border-[#E6E1F5] shadow-sm p-6 relative">
        <div className="absolute top-0 right-0 bg-[#6F52E7]/10 text-[#6F52E7] text-[10px] font-bold font-display px-3 py-1.5 rounded-bl-2xl uppercase tracking-wider border-l border-b border-[#E6E1F5]">
          Gemini 3.5 Assistant
        </div>

        <div className="flex items-center gap-2 mb-2">
          <BrainCircuit className="w-5 h-5 text-[#6F52E7]" />
          <h3 className="font-bold font-display text-neutral-950 text-base">Ask Gemini About Your Shop</h3>
        </div>
        <p className="text-xs text-[#6B6687] mb-6 font-display">
          Gemini will analyze your sales logs, shelf inventories, and day density patterns to deliver practical recommendations for Shyam's Street Stall.
        </p>

        {/* Input box */}
        <div className="space-y-4">
          <div className="relative">
            <input
              type="text"
              value={question}
              onChange={(e) => setQuestion(e.target.value)}
              onKeyDown={(e) => {
                if (e.key === "Enter" && !loading) handleAskAI("");
              }}
              placeholder="e.g., Why did Malt sales fall last week, and how can I boost them?"
              className="w-full pl-5 pr-14 py-3 bg-white border border-[#D3CDE8] rounded-full text-xs focus:outline-none focus:border-[#6F52E7] text-neutral-950"
              disabled={loading}
            />
            <button
              onClick={() => handleAskAI("")}
              disabled={loading || !question.trim()}
              className="absolute right-1.5 top-1.5 p-2 text-white bg-[#16142E] rounded-full hover:bg-[#6F52E7] hover:shadow-[0_4px_10px_rgba(111,82,231,0.3)] disabled:opacity-30 cursor-pointer transition-all"
            >
              <Send className="w-3.5 h-3.5" />
            </button>
          </div>

          {/* Quick suggestion prompt labels */}
          <div className="flex flex-wrap gap-2 pt-1">
            {QUICK_PROMPTS.map((prompt, idx) => (
              <button
                key={idx}
                onClick={() => !loading && handleAskAI(prompt.query)}
                className="px-3.5 py-1.5 bg-[#6F52E7]/5 hover:bg-[#6F52E7]/10 text-[#6F52E7] text-[10px] font-bold rounded-full border border-[#6F52E7]/15 transition-all flex items-center gap-1.5 cursor-pointer font-display"
                disabled={loading}
              >
                <HelpCircle className="w-3" />
                <span>{prompt.text}</span>
              </button>
            ))}
          </div>

          {/* Output responses */}
          {loading && (
            <div className="p-8 text-center flex flex-col items-center justify-center gap-2 border border-dashed border-[#D3CDE8] rounded-2xl bg-[#F8F6FE]">
              <Sparkles className="w-6 h-6 text-[#6F52E7] animate-pulse" />
              <p className="text-xs text-[#6B6687] animate-pulse font-mono mt-1">✨ Gemini is digesting your sales ledger and structuring smart metrics...</p>
            </div>
          )}

          {answer && (
            <motion.div
              initial={{ opacity: 0, y: 5 }}
              animate={{ opacity: 1, y: 0 }}
              className="p-4 bg-[#F1EDFE] border border-[#D3CDE8] rounded-2xl text-xs text-[#16142E] leading-relaxed font-sans whitespace-pre-line"
            >
              <div className="font-display font-extrabold text-[#6F52E7] text-[10px] uppercase tracking-wider mb-2 flex items-center gap-1.5">
                <Sparkles className="w-3.5 h-3.5 text-[#ECC785]" />
                <span>Gemini Analysis Response</span>
              </div>
              {answer}
            </motion.div>
          )}
        </div>
      </div>

      {/* Dynamic Sales ledger bar graph */}
      <div className="bg-brand-surface rounded-3xl border border-[#E6E1F5] shadow-sm p-6">
        <div className="flex items-center gap-2 mb-2">
          <ChartIcon className="w-5 h-5 text-[#16142E]" />
          <h3 className="font-bold font-display text-neutral-950 text-base">Earthy Revenue Trend</h3>
        </div>
        <p className="text-xs text-[#6B6687] mb-6">
          Track revenue collections dynamically. Watch weekend sales peaks rise.
        </p>

        {revenueData.length === 0 ? (
          <div className="p-12 text-center bg-[#F8F6FE] border border-[#E6E1F5] rounded-2xl text-xs text-[#6B6687] font-medium">
            No transaction records compiled.
          </div>
        ) : (
          <div className="h-[250px] w-full font-mono text-[10px] mt-4">
            <ResponsiveContainer width="100%" height="100%">
              <BarChart data={revenueData} margin={{ top: 10, right: 10, left: -20, bottom: 5 }}>
                <CartesianGrid strokeDasharray="3 3" stroke="#E6E1F5" />
                <XAxis dataKey="date" stroke="#6B6687" style={{ fontSize: "10px" }} />
                <YAxis stroke="#6B6687" style={{ fontSize: "10px" }} />
                <Tooltip
                  cursor={{ fill: "rgba(111, 82, 231, 0.05)" }}
                  contentStyle={{ background: "#FFFFFF", border: "1px solid #E6E1F5", borderRadius: "12px", fontSize: "11px" }}
                />
                <Bar dataKey="Revenue" fill="#6F52E7" radius={[6, 6, 0, 0]} barSize={28} />
              </BarChart>
            </ResponsiveContainer>
          </div>
        )}
      </div>
    </div>
  );
}
